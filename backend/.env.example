# Copy to backend/.env and fill in.  Never commit the real .env.

# --- Local docker-compose Postgres (default) ---
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=appdb
PGSSLMODE=prefer

# --- Azure Database for PostgreSQL (office) ---
# PGHOST=zaf-phoenix-postgres.postgres.database.azure.com
# PGUSER=zafadmin
# PGPASSWORD=<set-a-secret-do-not-hardcode>
# PGDATABASE=postgres
# PGSSLMODE=require

# Safety / limits
MAX_ROWS=1000
QUERY_TIMEOUT_SECONDS=15

# Comma-separated origins allowed to call the API (Vite dev server)
CORS_ORIGINS=http://localhost:5173

# --- Optional: AI natural-language -> SQL (adds a tick box in the UI) ---
# Leave disabled to use the built-in rule-based question mapping (no key needed).
LLM_ENABLED=false
# provider: azure_openai | openai | groq | gemini | anthropic | mock  (mock = keyless demo)
LLM_PROVIDER=azure_openai
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=
# Azure OpenAI only:
AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-06-01
#
# Other providers (set LLM_PROVIDER + LLM_MODEL + LLM_API_KEY):
#   groq    -> LLM_MODEL=llama-3.3-70b-versatile   (OpenAI-compatible, free tier)
#   gemini  -> LLM_MODEL=gemini-2.5-flash
#   openai  -> LLM_MODEL=gpt-4o-mini
#   anthropic -> LLM_MODEL=claude-...
